{% comment %}
  Trust Badges - App Block (product pages)
  Shows trust/payment badges below Add to Cart.
  No backend needed - all config via Theme Editor.
{% endcomment %}

<div class="tb-container" style="
  --tb-icon-size: {{ block.settings.icon_size }}px;
  --tb-text-color: {{ block.settings.text_color }};
  --tb-icon-color: {{ block.settings.icon_color }};
  --tb-bg: {{ block.settings.background_color }};
">
  <div class="tb-grid tb-layout-{{ block.settings.layout }}">
    {% if block.settings.badge_1_text != blank %}
      <div class="tb-badge">
        <span class="tb-icon">{{ block.settings.badge_1_icon }}</span>
        <span class="tb-text">{{ block.settings.badge_1_text }}</span>
      </div>
    {% endif %}
    {% if block.settings.badge_2_text != blank %}
      <div class="tb-badge">
        <span class="tb-icon">{{ block.settings.badge_2_icon }}</span>
        <span class="tb-text">{{ block.settings.badge_2_text }}</span>
      </div>
    {% endif %}
    {% if block.settings.badge_3_text != blank %}
      <div class="tb-badge">
        <span class="tb-icon">{{ block.settings.badge_3_icon }}</span>
        <span class="tb-text">{{ block.settings.badge_3_text }}</span>
      </div>
    {% endif %}
    {% if block.settings.badge_4_text != blank %}
      <div class="tb-badge">
        <span class="tb-icon">{{ block.settings.badge_4_icon }}</span>
        <span class="tb-text">{{ block.settings.badge_4_text }}</span>
      </div>
    {% endif %}
    {% if block.settings.badge_5_text != blank %}
      <div class="tb-badge">
        <span class="tb-icon">{{ block.settings.badge_5_icon }}</span>
        <span class="tb-text">{{ block.settings.badge_5_text }}</span>
      </div>
    {% endif %}
    {% if block.settings.badge_6_text != blank %}
      <div class="tb-badge">
        <span class="tb-icon">{{ block.settings.badge_6_icon }}</span>
        <span class="tb-text">{{ block.settings.badge_6_text }}</span>
      </div>
    {% endif %}
  </div>
</div>

{{ 'trust-badges.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Trust Badges",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid (2 columns)" },
        { "value": "inline", "label": "Inline Row" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 16,
      "max": 32,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#5C6AC4"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f8f8f8"
    },
    {
      "type": "text",
      "id": "badge_1_icon",
      "label": "Badge 1 Icon",
      "default": "🚚"
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Badge 1 Text",
      "default": "Free Shipping"
    },
    {
      "type": "text",
      "id": "badge_2_icon",
      "label": "Badge 2 Icon",
      "default": "💳"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Badge 2 Text",
      "default": "COD Available"
    },
    {
      "type": "text",
      "id": "badge_3_icon",
      "label": "Badge 3 Icon",
      "default": "🔒"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Badge 3 Text",
      "default": "Secure Payment"
    },
    {
      "type": "text",
      "id": "badge_4_icon",
      "label": "Badge 4 Icon",
      "default": "📦"
    },
    {
      "type": "text",
      "id": "badge_4_text",
      "label": "Badge 4 Text",
      "default": "Easy Returns"
    },
    {
      "type": "text",
      "id": "badge_5_icon",
      "label": "Badge 5 Icon",
      "default": "✅"
    },
    {
      "type": "text",
      "id": "badge_5_text",
      "label": "Badge 5 Text",
      "default": "100% Genuine"
    },
    {
      "type": "text",
      "id": "badge_6_icon",
      "label": "Badge 6 Icon"
    },
    {
      "type": "text",
      "id": "badge_6_text",
      "label": "Badge 6 Text"
    }
  ]
}
{% endschema %}
